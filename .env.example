# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Find these in your Supabase project settings:
#   Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER prefix with NEXT_PUBLIC)
# Needed for client-facing (no-login) pages that must securely fetch data server-side.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Google Drive (service account)
# -----------------------------------------------------------------------------
# Folder ID from:
# https://drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=14iBNOke8F3YOg4oSzYV6dgJ0cW5BKHqo

# Base64 of your service account JSON key file.
# You'll generate this locally with:
#   node scripts/base64-service-account.mjs path/to/key.json
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Used for generating absolute links in a few places (optional but recommended)
APP_BASE_URL=http://localhost:3000

